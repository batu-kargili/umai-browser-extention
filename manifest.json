{
  "name": "DuvarAI Browser LLM Governance (MVP)",
  "version": "0.1.0",
  "manifest_version": 3,
  "description": "Enterprise browser governance for ChatGPT, Gemini, and Claude with DuvarAI policy enforcement.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://duvarai-service-442107147924.europe-west3.run.app/*",
    "https://duvarai-service-mhkvrwuj2q-ey.a.run.app/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "DuvarAI Extension",
    "default_popup": "popup.html"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://duvarai-controlcenter-442107147924.europe-west3.run.app/*",
      "https://duvarai-controlcenter-mhkvrwuj2q-ey.a.run.app/*"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content_chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content_gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content_claude.js"],
      "run_at": "document_idle"
    }
  ],
  "storage": {
    "managed_schema": "schema.json"
  },
  "minimum_chrome_version": "120"
}
